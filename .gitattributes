import mysql.connector

# Connect to the MySQL database
def connect_db():
    return mysql.connector.connect(
        host="localhost",
        user="your_username",  # Replace with your MySQL username
        password="your_password",  # Replace with your MySQL password
        database="StudentManagement"
    )

# Add Student
def add_student():
    db = connect_db()
    cursor = db.cursor()
    
    rollno = int(input("Enter roll number: "))
    name = input("Enter student name: ")
    english = float(input("Enter English marks: "))
    maths = float(input("Enter Maths marks: "))
    chemistry = float(input("Enter Chemistry marks: "))
    physics = float(input("Enter Physics marks: "))
    computerscience = float(input("Enter Computer Science marks: "))
    
    cursor.execute("""
        INSERT INTO students (rollno, name, english, maths, chemistry, physics, computerscience)
        VALUES (%s, %s, %s, %s, %s, %s, %s)
    """, (rollno, name, english, maths, chemistry, physics, computerscience))
    
    db.commit()
    cursor.close()
    db.close()
    print("Student added successfully!")

# Display All Students
def display_students():
    db = connect_db()
    cursor = db.cursor(dictionary=True)
    
    cursor.execute("SELECT * FROM students")
    for student in cursor.fetchall():
        print(student)
    
    cursor.close()
    db.close()

# Modify Student Record
def modify_student():
    db = connect_db()
    cursor = db.cursor()
    
    rollno = int(input("Enter roll number to modify: "))
    subject = input("Enter subject to modify (english, maths, chemistry, physics, computerscience): ").lower()
    new_score = float(input(f"Enter new score for {subject}: "))
    
    cursor.execute(f"UPDATE students SET {subject} = %s WHERE rollno = %s", (new_score, rollno))
    db.commit()
    
    cursor.close()
    db.close()
    print("Student record updated successfully!")

# Delete Student Record
def delete_student():
    db = connect_db()
    cursor = db.cursor()
    
    rollno = int(input("Enter roll number to delete: "))
    
    cursor.execute("DELETE FROM students WHERE rollno = %s", (rollno,))
    db.commit()
    
    cursor.close()
    db.close()
    print("Student record deleted successfully!")

# Main menu loop
def main_menu():
    while True:
        print("\nWelcome to the Student Result Management System")
        print("1. Add Student")
        print("2. Display All Students Records")
        print("3. Modify Student Record")
        print("4. Delete Student Record")
        print("5. Exit")

        choice = int(input("Enter your choice: "))

        if choice == 1:
            add_student()
        elif choice == 2:
            display_students()
        elif choice == 3:
            modify_student()
        elif choice == 4:
            delete_student()
        elif choice == 5:
            print("Exiting the program...")
            break
        else:
            print("Invalid choice. Please enter a number between 1 and 5.")

if _name_ == "_main_":
    main_menu()
